{
  "name": "@vercel/vite-browser",
  "version": "0.1.0",
  "description": "Programmatic access to Vue/React DevTools and Vite dev server for AI agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/vite-browser.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "extensions"
  ],
  "bin": {
    "vite-browser": "./dist/cli.js"
  },
  "scripts": {
    "start": "node --loader tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "playwright": "^1.50.0",
    "source-map-js": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vue/devtools-kit": "^7.3.2",
    "@vue/devtools-api": "^7.3.2",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@10.29.2"
}
